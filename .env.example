# ── 必須 ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_api_key_here

# ── Phase 1: Notion連携（オプション） ────────────────────
# Notionインテグレーションページで取得: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxx
# データベースページURLの末尾32文字
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Phase 1: Gmail連携（オプション） ─────────────────────
# Googleアカウント → セキュリティ → アプリパスワード で生成
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_TO=recipient@example.com

# ── Phase 2: Computer Use（オプション） ───────────────────
COMPUTER_USE_MODEL=claude-opus-4-5

# ── 通知設定 ──────────────────────────────────────────────
NOTIFY_ON_COMPLETE=true
